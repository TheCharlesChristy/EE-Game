# Production environment configuration for Raspberry Pi deployment.
# Copy to /opt/ee-game/host/backend/.env and fill in values.
# This file is committed as a template only — never commit the actual .env.
#
# SRS reference: Section 13.1 (Deployment), AC-011.

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
HEARTBEAT_TIMEOUT_SECONDS=30

# Path to the built React frontend (relative to host/backend/).
# The backend mounts this directory as static files at the root URL.
# Ensure host/frontend/dist/ has been built and copied before starting the service.
STATIC_FILES_DIR=../frontend/dist
