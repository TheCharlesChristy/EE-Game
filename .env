# EE-Game configuration
# Copied to /opt/ee-game/host/backend/.env by install-pi.sh.
# Edit values there after installation; changes take effect on service restart.

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=WARNING
HEARTBEAT_TIMEOUT_SECONDS=30
STATIC_FILES_DIR=../../frontend/dist

# ── WiFi access point ─────────────────────────────────────────────────────────
# These must match the hostapd config written by install-pi.sh.
# WIFI_PASSWORD is also baked into ESP32 firmware at flash time (ee-game flash).
WIFI_SSID=ee-game
WIFI_PASSWORD=password123

# ── Firmware / device connection ──────────────────────────────────────────────
# IP address of the Pi on the WiFi AP subnet.
# Injected into firmware as BACKEND_HOST at compile time.
BACKEND_AP_HOST=192.168.4.1
